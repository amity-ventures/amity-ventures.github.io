#!/bin/sh

set -eu

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if ! command -v node >/dev/null 2>&1; then
  echo "pre-commit: node is required to sync site content" >&2
  exit 1
fi

node scripts/sync-site-content.mjs

if ! git diff --quiet -- index.html skill.md; then
  git add -- index.html skill.md
  echo "pre-commit: synced site content"
fi
